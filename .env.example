# Upstream LLM API. Default: OpenAI. Works with any OpenAI-compatible endpoint
# (Anthropic via oai-compat, OpenRouter, Groq, Together, local vLLM, etc.)
MIDSENTENCE_UPSTREAM=https://api.openai.com

# API key for DEBRIEF calls (the "ask why" button).
# The proxy itself forwards the client's Authorization header through to the
# upstream, so your app keeps using its own key — this one is only used when
# YOU ask follow-up questions to the model.
MIDSENTENCE_API_KEY=sk-...

# Server port (default 8765)
MIDSENTENCE_PORT=8765
